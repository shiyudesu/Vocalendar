# API
PORT=8061
NODE_ENV=development

# Database
DATABASE_URL=postgresql://vocalendar:vocalendar@127.0.0.1:5432/vocalendar

# Redis
# Option 1: Use a single URL (backward compatible)
REDIS_URL=redis://127.0.0.1:6379
# Option 2: Use separate host/port/password (special chars in password are safe)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Voice / Aliyun
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_NLS_APP_KEY=your-aliyun-nls-app-key
ALIYUN_ASR_REGION=cn-shanghai
ALIYUN_TTS_REGION=cn-shanghai
ALIYUN_NLS_GATEWAY_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
ALIYUN_NLS_TOKEN_DOMAIN=nls-meta.cn-shanghai.aliyuncs.com
ALIYUN_NLS_TOKEN_TTL_SECONDS=3600
ALIYUN_DEFAULT_LANGUAGE=zh-CN

# Export
EXPORT_TEMP_DIR=/tmp/vocalendar-export

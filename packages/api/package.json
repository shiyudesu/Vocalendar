{
  "name": "@vocalendar/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsdown src/index.ts --format esm --platform node --out-dir dist --clean",
    "check": "rslint --type-check . && oxfmt --check .",
    "test": "vitest run",
    "fix": "rslint --type-check --fix . && oxfmt ."
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@vocalendar/schemas": "workspace:*",
    "chrono-node": "^2.9.0",
    "hono": "4.12.23"
  },
  "devDependencies": {
    "@rslint/core": "^0.5.3",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.52.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.0.15"
  }
}
